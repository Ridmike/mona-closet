rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if the authenticated user has administrative privileges
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Owner' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Staff');
    }

    // Rules for the users collection
    match /users/{userId} {
      // Allow read to let guest checkouts query existing customer emails
      allow read: if true;
      // Allow creating a customer profile document (e.g. guest conversion or sign-in)
      allow create: if request.resource.data.role == 'Customer';
      // Only the profile owner or admins can modify/delete it
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for the products collection
    match /products/{productId} {
      // Anyone (including guest users) can browse products
      allow read: if true;
      // Only admins can create/delete products
      allow create, delete: if isAdmin();
      // Admins can update anything. Authenticated users can update for stock deduction.
      // Note: updateDoc sends partial fields, so request.resource.data.diff() cannot be used.
      allow update: if isAdmin() || isAuthenticated();
    }

    // Rules for the categories collection
    match /categories/{categoryId} {
      // Anyone can browse categories
      allow read: if true;
      // Only admins can create or edit categories
      allow write: if isAdmin();
    }

    // Rules for the orders collection
    match /orders/{orderId} {
      // Admins can read all orders.
      // Any authenticated user can list orders — the SDK query always includes
      // a where("customerId","==",uid) or where("customerEmail","==",email) filter,
      // so users can only receive their own documents in practice.
      allow list: if isAuthenticated();
      allow get:  if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      // Anyone (including guest users) can create an order. Only admins can update/delete.
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Rules for the pages collection
    match /pages/{pageId} {
      // Anyone can read pages content. Only admins can modify.
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the faqs collection
    match /faqs/{faqId} {
      // Anyone can read FAQ lists. Only admins can edit them.
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the contact messages collection
    match /contact_messages/{msgId} {
      // Anyone (even guests) can submit a contact message. Only admins can read/delete them.
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
